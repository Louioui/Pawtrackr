"tour.co.details.directive" = "Documenta lo que pasó durante el aseo.";
"tour.co.details.purpose" = "Notas, etiquetas de comportamiento y fotos de antes/después quedan adjuntas a esta visita para que el historial cuente la historia completa después, no solo el precio.";
"tour.co.details.tip" = "Usa etiquetas de comportamiento para patrones de seguridad que el equipo debe recordar la próxima vez.";
