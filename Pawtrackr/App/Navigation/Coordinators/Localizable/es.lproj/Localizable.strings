"tour.co.review.title" = "Cobro: revisión";
"tour.co.review.directive" = "Revisa el registro antes de guardarlo.";
"tour.co.review.purpose" = "Revisión muestra mascota, duración, servicios, notas, fotos, detalles de pago y lo que se guardará en historial antes de actualizar estadísticas.";
