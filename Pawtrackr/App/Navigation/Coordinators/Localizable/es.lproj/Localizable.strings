"tour.co.confirm.directive" = "Esta es la meta real del cobro.";
"tour.co.confirm.purpose" = "Confirmar y pagar completa la visita, guarda el pago, actualiza el historial del cliente y la mascota, refresca estadísticas y prepara detalles del recibo. El walkthrough sigue sin cobrar ni guardar un cobro de demo.";
"tour.co.confirm.tip" = "En uso real, presiona esto solo cuando el cliente ya pagó y los detalles de la visita estén correctos.";
